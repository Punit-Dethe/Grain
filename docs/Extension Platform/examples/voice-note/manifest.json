{
  "id": "com.example.voice-note",
  "name": "Voice Note",
  "version": "0.1.0",
  "grainApi": "^1.0",
  "tier": "scripted",
  "description": "Structures a dictated note, stores it, and suppresses paste",
  "entry": "dist/main.js",
  "permissions": ["session:start", "llm", "storage"],
  "activation": [],
  "contributes": {
    "sessionMode": {
      "id": "note",
      "label": "Dictate a voice note",
      "default_binding": "Ctrl+Shift+N"
    }
  }
}
