{
  "id": "com.example.workspace-surface",
  "name": "Workspace Surface",
  "version": "0.1.0",
  "grainApi": "^1.0",
  "tier": "scripted",
  "description": "Opens a host-owned workspace from a shortcut",
  "entry": "dist/main.js",
  "permissions": ["surface:workspace"],
  "activation": ["onShortcut:open"],
  "surfaces": {
    "workspace": {
      "title": "Example Workspace",
      "min_size": [640, 420],
      "ui_source": "<!doctype html><meta charset=\"utf-8\"><style>body{font:16px system-ui;padding:24px;background:#f7f4ee;color:#211f1b}button{padding:8px 12px}</style><main><h1>Example Workspace</h1><p id=\"message\">Waiting for a payload...</p><button onclick=\"grain.workspace.close()\">Close</button></main><script>grain.onEvent(function(payload){if(payload&&payload.message){document.getElementById('message').textContent=payload.message;}});<\/script>"
    }
  },
  "contributes": {
    "shortcuts": [
      {
        "id": "open",
        "label": "Open example workspace"
      }
    ]
  }
}
